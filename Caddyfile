# Caddyfile — production reverse proxy
# Replace catchaprayer.com with your actual domain

{$DOMAIN:catchaprayer.com} {
	# API — proxy to FastAPI
	handle /api/* {
		reverse_proxy api:8000
	}

	# Health check endpoint (no cache)
	handle /health {
		reverse_proxy api:8000
	}

	# API docs
	handle /docs {
		reverse_proxy api:8000
	}
	handle /openapi.json {
		reverse_proxy api:8000
	}

	# Prometheus (admin only — restrict in Cloudflare or use basic auth)
	handle /prometheus/* {
		basicauth {
			admin {$PROMETHEUS_PASSWORD_HASH}
		}
		reverse_proxy prometheus:9090
	}

	# Everything else — serve the React frontend
	handle {
		root * /srv/web
		try_files {path} /index.html
		file_server
		encode gzip

		header {
			# Cache static assets aggressively
			Cache-Control "public, max-age=31536000, immutable" {
				path /static/*
			}
			# Don't cache index.html
			Cache-Control "no-cache, no-store, must-revalidate" {
				path /index.html
			}
		}
	}
}
