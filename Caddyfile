{
	auto_https off
}

:80 {
	handle /api/* {
		reverse_proxy api:8000
	}
	handle /health {
		reverse_proxy api:8000
	}
	handle /docs {
		reverse_proxy api:8000
	}
	handle /openapi.json {
		reverse_proxy api:8000
	}
	handle /prometheus/* {
		reverse_proxy prometheus:9090
	}
	handle {
		root * /srv/web
		try_files {path} /index.html
		file_server
		encode gzip
		header {
			Cache-Control "public, max-age=31536000, immutable" {
				path /static/*
			}
			Cache-Control "no-cache, no-store, must-revalidate" {
				path /index.html
			}
		}
	}
}
