# ─── Production Environment ───────────────────────────────────────────────────
# Copy this to .env.prod and fill in real values
# NEVER commit .env.prod to git

# Database (internal Docker network — no external access)
DATABASE_URL=postgresql+asyncpg://cap:CHANGE_THIS_PASSWORD@db:5432/catchaprayer
POSTGRES_USER=cap
POSTGRES_PASSWORD=CHANGE_THIS_PASSWORD
POSTGRES_DB=catchaprayer

# API Keys
MAPBOX_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_PLACES_API_KEY=

# Scraping
OVERPASS_API_URL=https://overpass-api.de/api/interpreter
PLAYWRIGHT_WORKERS=2

# Domain (used by Caddyfile)
DOMAIN=catchaprayer.com

# OpenClaw (AI agent)
OPENCLAW_GATEWAY_TOKEN=
WHATSAPP_NUMBER=

# Prometheus admin password hash (generate with: caddy hash-password)
PROMETHEUS_PASSWORD_HASH=
